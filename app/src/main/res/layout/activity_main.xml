<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg"
    android:gravity="center_horizontal">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:id="@+id/Nombra_mascota"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Tarjeta con imagen (redondeada + sombra) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardMascota"
                android:layout_width="260dp"
                android:layout_height="321dp"
                android:layout_marginTop="36dp"
                app:cardCornerRadius="18dp"
                app:cardElevation="10dp"
                app:strokeWidth="0dp">

                <ImageView
                    android:id="@+id/imgMascota"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:contentDescription="@string/pet_image_desc"
                    android:scaleType="centerCrop"
                    android:src="@drawable/fotogato" />
            </com.google.android.material.card.MaterialCardView>

            <!-- Nombre -->
            <TextView
                android:id="@+id/txtNombreMascota"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="@string/pet_name"
                android:textColor="@color/textPrimary"
                android:textSize="32sp"
                android:textStyle="bold" />

            <!-- Edad -->
            <TextView
                android:id="@+id/txtEdadMascota"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/pet_age"
                android:textColor="@color/textSecondary"
                android:textSize="22sp" />

            <!-- Input subrayado -->
            <EditText
                android:id="@+id/edtAdoptante"
                android:layout_width="320dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:backgroundTint="@color/accent"
                android:hint="@string/adopter_hint"
                android:inputType="textPersonName"
                android:paddingTop="10dp"
                android:paddingBottom="10dp"
                android:textColor="@color/textPrimary"
                android:textColorHint="@color/textHint"
                android:textSize="18sp" />

            <!-- Widget: estrellas -->
            <RatingBar
                android:id="@+id/rating"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:numStars="5"
                android:rating="4"
                android:stepSize="1" />

            <!-- Barra de progreso (color personalizado) -->

            <!-- Botones (redondeados + sombra) -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="26dp"
                android:gravity="center"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnAdoptar"
                    android:layout_width="150dp"
                    android:layout_height="54dp"
                    android:backgroundTint="@color/accent"
                    android:elevation="8dp"
                    android:stateListAnimator="@null"
                    android:text="@string/btn_adopt"
                    android:textColor="@android:color/white"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    app:cornerRadius="18dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnContactar"
                    android:layout_width="150dp"
                    android:layout_height="54dp"
                    android:layout_marginStart="14dp"
                    android:backgroundTint="@color/btnDark"
                    android:elevation="8dp"
                    android:stateListAnimator="@null"
                    android:text="@string/btn_contact"
                    android:textColor="@android:color/white"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    app:cornerRadius="18dp" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</LinearLayout>